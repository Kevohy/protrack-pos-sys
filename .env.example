# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Hetzner private network hostname on VPS)
# Format for Dokploy/Docker: use the internal service hostname, not 127.0.0.1
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Public URL of this deployment (no trailing slash)
NEXTAUTH_URL="https://your-domain.com"

# Random secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV="production"
